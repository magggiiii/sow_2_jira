# .env.example

# --- Universal LLM Configuration (LiteLLM) ---
# Use any model string supported by LiteLLM (e.g., gpt-4o, anthropic/claude-3-5-sonnet, ollama/qwen2.5)
LITELLM_MODEL=gpt-4o
LITELLM_API_KEY=sk-...
LITELLM_API_BASE=https://api.openai.com/v1

# --- Jira Configuration ---
JIRA_SERVER=https://your-domain.atlassian.net
JIRA_API_TOKEN=...
JIRA_EMAIL=...

# --- Telemetry & Observability ---
# BIFROST_GATEWAY_URL: Unified gateway for logs (Loki) and traces (Tempo).
# If running app in Docker and deck on host, use: http://localhost:8080 (auto-translated to host.docker.internal)
BIFROST_GATEWAY_URL=http://localhost:8080

# BIFROST_BACKBONE_TOKEN: Authentication token for the central observability deck.
BIFROST_BACKBONE_TOKEN=

# (Optional) Specific overrides if Loki/Tempo are on different gateways
BIFROST_LOKI_URL=
BIFROST_TELEMETRY_URL=
BIFROST_TELEMETRY_TOKEN=

# --- Security & Paths ---
# The installer sets this to ~/.sow_to_jira/data automatically
SOW_DATA_DIR=data
MAX_NODES=50
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:8000